########################################
# Atelier ERP — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit the real .env file.
########################################

# ---- General ----
NODE_ENV=development

# ---- Database (PostgreSQL) ----
POSTGRES_USER=atelier
POSTGRES_PASSWORD=atelier_dev_password
POSTGRES_DB=atelier_erp
POSTGRES_PORT=5432
DATABASE_URL=postgresql://atelier:atelier_dev_password@localhost:5432/atelier_erp?schema=public

# ---- Redis (cache / queues / sessions) ----
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ---- API (NestJS) ----
API_PORT=4000
API_URL=http://localhost:4000

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:3000

# ---- Web (Next.js) ----
WEB_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# ---- Multi-tenancy ----
DEFAULT_TENANT_PLAN=free
