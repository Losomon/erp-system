// Atelier ERP — Prisma schema
// STEP 1: Organization, User, Membership — proved the DB/ORM pipeline.
// STEP 2 (this revision): adds Role/Permission RBAC, RefreshToken for
// session management, and AuditLog for tracking sensitive actions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// A tenant / company using the platform. Everything in the ERP
/// is scoped to an Organization to keep the system multi-tenant.
model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships Membership[]
  roles       Role[]
  auditLogs   AuditLog[]

  customers        Customer[]
  productCategories ProductCategory[]
  products         Product[]
  warehouses       Warehouse[]
  stockMovements   StockMovement[]
  salesOrders      SalesOrder[]
  invoices         Invoice[]
  payments         Payment[]

  @@map("organizations")
}

/// A person who can log in. A single User can belong to multiple
/// Organizations through Membership (e.g. a consultant working
/// with several client companies).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  firstName    String
  lastName     String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  memberships   Membership[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  @@map("users")
}

/// Join table linking a User to an Organization with a single Role.
/// This is the seat that determines what the user can do inside
/// that specific organization.
model Membership {
  id             String   @id @default(cuid())
  userId         String
  organizationId String
  roleId         String
  createdAt      DateTime @default(now())

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  role         Role         @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([userId, organizationId])
  @@map("memberships")
}

/// A role scoped to one Organization. Every organization gets its own
/// copy of the default roles (Owner, Admin, Manager, Accountant,
/// Sales Staff, Employee) when it's created, seeded with sensible
/// default permissions. `isSystem` roles can't be deleted or renamed;
/// organizations can still add their own custom roles later.
model Role {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  isSystem       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@unique([organizationId, name])
  @@map("roles")
}

/// The global catalog of permissions the system understands, e.g.
/// "customers.read", "invoices.approve". Not organization-scoped —
/// this is the fixed vocabulary every Role draws from.
model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  description String
  createdAt   DateTime @default(now())

  rolePermissions RolePermission[]

  @@map("permissions")
}

/// Join table attaching Permissions to a Role.
model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

/// A long-lived refresh token issued at login, used to mint new
/// access tokens without forcing the user to log in again. Stored
/// as a hash, never the raw token. Revoked on logout.
model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

/// A record of a sensitive action taken in the system. organizationId
/// and userId are nullable because a handful of actions (e.g. a failed
/// login attempt before we know who it is) don't have both.
model AuditLog {
  id             String   @id @default(cuid())
  organizationId String?
  userId         String?
  action         String
  entityType     String?
  entityId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@map("audit_logs")
}

// ============================================================
// STEP 3 — Core ERP
// CRM → Products/Inventory → Sales → Invoicing → Payments
// Every model below carries organizationId directly (rather than
// only through a relation chain) so every query can filter on it
// without joins — the first line of multi-tenant defense.
// ============================================================

enum CustomerStatus {
  ACTIVE
  ARCHIVED
}

model Customer {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  address        String?
  status         CustomerStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  salesOrders  SalesOrder[]
  invoices     Invoice[]

  @@index([organizationId])
  @@map("customers")
}

/// A named person at a Customer (useful for B2B accounts with
/// multiple points of contact).
model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  email      String?
  phone      String?
  role       String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@map("contacts")
}

enum ProductStatus {
  ACTIVE
  ARCHIVED
}

model ProductCategory {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  products     Product[]

  @@unique([organizationId, name])
  @@map("product_categories")
}

model Product {
  id             String        @id @default(cuid())
  organizationId String
  categoryId     String?
  sku            String
  name           String
  description    String?
  price          Decimal       @db.Decimal(12, 2)
  cost           Decimal       @default(0) @db.Decimal(12, 2)
  taxRate        Decimal       @default(0) @db.Decimal(5, 2)
  status         ProductStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category         ProductCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryStocks  InventoryStock[]
  stockMovements   StockMovement[]
  salesOrderItems  SalesOrderItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@map("products")
}

model Warehouse {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  address        String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())

  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inventoryStocks InventoryStock[]
  stockMovements  StockMovement[]

  @@unique([organizationId, name])
  @@map("warehouses")
}

/// The cached current stock level for a Product at a Warehouse.
/// This is a read-optimized projection — the source of truth is
/// the StockMovement ledger below; every movement updates this
/// row's `quantity` inside the same transaction.
model InventoryStock {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  quantity    Int      @default(0)
  updatedAt   DateTime @updatedAt

  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@unique([productId, warehouseId])
  @@map("inventory_stock")
}

enum StockMovementType {
  PURCHASE
  SALE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
}

/// The append-only ledger every stock change is recorded against.
/// `quantity` is a signed delta (positive = stock added, negative =
/// stock removed) so the current level is always sum(quantity) —
/// and InventoryStock.quantity above should always equal that sum.
model StockMovement {
  id             String            @id @default(cuid())
  organizationId String
  productId      String
  warehouseId    String
  type           StockMovementType
  quantity       Int
  reference      String?
  createdByUserId String?
  createdAt      DateTime          @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  @@index([organizationId, productId, warehouseId])
  @@map("stock_movements")
}

enum SalesOrderStatus {
  DRAFT
  CONFIRMED
  PROCESSING
  COMPLETED
  CANCELLED
}

model SalesOrder {
  id              String           @id @default(cuid())
  organizationId  String
  customerId      String
  orderNumber     String
  status          SalesOrderStatus @default(DRAFT)
  subtotal        Decimal          @default(0) @db.Decimal(12, 2)
  tax             Decimal          @default(0) @db.Decimal(12, 2)
  total           Decimal          @default(0) @db.Decimal(12, 2)
  createdByUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        SalesOrderItem[]
  invoices     Invoice[]

  @@unique([organizationId, orderNumber])
  @@index([organizationId])
  @@map("sales_orders")
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String
  quantity     Int
  unitPrice    Decimal @db.Decimal(12, 2)
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  lineTotal    Decimal @db.Decimal(12, 2)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([salesOrderId])
  @@map("sales_order_items")
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PARTIALLY_PAID
  PAID
  OVERDUE
  VOID
}

model Invoice {
  id             String        @id @default(cuid())
  organizationId String
  salesOrderId   String?
  customerId     String
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  tax            Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(12, 2)
  issuedAt       DateTime?
  dueAt          DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  salesOrder   SalesOrder?   @relation(fields: [salesOrderId], references: [id], onDelete: SetNull)
  customer     Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  items        InvoiceItem[]
  payments     Payment[]

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int
  unitPrice   Decimal @db.Decimal(12, 2)
  taxRate     Decimal @default(0) @db.Decimal(5, 2)
  lineTotal   Decimal @db.Decimal(12, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@map("invoice_items")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD
  MOBILE_MONEY
  OTHER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

model Payment {
  id             String        @id @default(cuid())
  organizationId String
  invoiceId      String
  amount         Decimal       @db.Decimal(12, 2)
  method         PaymentMethod
  status         PaymentStatus @default(COMPLETED)
  reference      String?
  paidAt         DateTime      @default(now())
  createdAt      DateTime      @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invoice      Invoice      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([organizationId, invoiceId])
  @@map("payments")
}

